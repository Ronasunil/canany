<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="<%= typeof robots === 'string' ? robots : 'noindex' %>">
  <meta name="color-scheme" content="dark">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500;700;800&family=Manrope:wght@700&family=Poppins:wght@400&family=Roboto:wght@400&display=swap" rel="stylesheet">
  <style>
    :root {
      /* Ink & Signal — a terminal that lives in Telegram, not a hacker-green console */
      --void: #0B0E15;
      --void-2: #090C12;
      --panel: #10141D;
      --panel-2: #161B26;
      --row-hover: #141926;
      --line: #232A38;
      --line-2: #2E374A;
      --text: #D4DAE4;
      --dim: #7E8A9C;
      --faint: #4D5667;
      /* signature accent — electric periwinkle (deliberately not green/clay/vermilion) */
      --violet: #877CF2;
      --violet-2: #A79CFF;
      --violet-wash: rgba(135, 124, 242, .13);
      --violet-line: rgba(135, 124, 242, .42);
      /* lifecycle, encoded as a filling circle ○ ◑ ● */
      --open: #E0A33C;
      --claimed: #4FB6CE;
      --done: #6FCF8E;
      /* urgency = the terminal's three traffic dots */
      --now: #E5604D;
      --eod: #E0A33C;
      --norush: #6FCF8E;
      --mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      --sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --radius: 12px;
      --shadow: 0 1px 0 rgba(255,255,255,.02) inset, 0 24px 60px -28px rgba(0,0,0,.85), 0 4px 18px -10px rgba(0,0,0,.6);
    }
    * { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      margin: 0;
      min-height: 100dvh;
      background: var(--void);
      /* faint signal glow behind the window, so the ink has depth */
      background-image:
        radial-gradient(1100px 520px at 50% -8%, rgba(135,124,242,.10), transparent 60%),
        radial-gradient(800px 600px at 92% 108%, rgba(79,182,206,.06), transparent 55%);
      background-attachment: fixed;
      color: var(--text);
      font: 500 14px/1.65 var(--mono);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }
    a { color: var(--violet-2); text-decoration: none; }
    a:hover { color: var(--violet-2); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; }
    code {
      font-family: var(--mono); font-size: .92em; color: var(--violet-2);
      background: var(--violet-wash); border: 1px solid var(--violet-line);
      padding: .5px 6px; border-radius: 5px;
    }
    :focus-visible {
      outline: 2px solid var(--violet);
      outline-offset: 2px;
      border-radius: 4px;
    }

    /* ---- The terminal window ---- */
    .term {
      width: 100%; max-width: 1060px; margin: clamp(18px, 5vw, 56px) auto;
      background: var(--panel);
      border: 1px solid var(--line-2);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: clip;
    }
    .term__bar {
      display: flex; align-items: center; gap: 14px;
      padding: 12px 16px;
      background: linear-gradient(var(--panel-2), var(--panel));
      border-bottom: 1px solid var(--line);
    }
    .dots { display: inline-flex; gap: 7px; flex: none; }
    .dots span {
      width: 11px; height: 11px; border-radius: 50%;
      box-shadow: 0 0 0 1px rgba(0,0,0,.25) inset;
    }
    .dots .d-now { background: var(--now); }
    .dots .d-eod { background: var(--eod); }
    .dots .d-norush { background: var(--norush); }
    .term__title {
      color: var(--dim); font-size: 12.5px; font-weight: 500; letter-spacing: .02em;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .term__title b { color: var(--text); font-weight: 700; }
    .term__spacer { flex: 1 1 auto; }
    .term__body { padding: clamp(22px, 4.5vw, 40px) clamp(16px, 4.5vw, 40px); }
    .term__foot {
      display: flex; flex-wrap: wrap; gap: 6px 16px;
      padding: 11px clamp(16px, 4.5vw, 24px);
      border-top: 1px solid var(--line);
      background: var(--void-2);
      color: var(--faint); font-size: 11.5px; letter-spacing: .02em;
    }
    .term__foot .sep { color: var(--line-2); }

    /* ---- Buttons ---- */
    button, .btn {
      font: 700 12.5px/1 var(--mono); cursor: pointer; letter-spacing: .02em;
      display: inline-flex; align-items: center; gap: 7px;
      color: var(--dim); background: transparent;
      border: 1px solid var(--line-2); border-radius: 7px;
      padding: 8px 13px; transition: color .15s, border-color .15s, background .15s;
    }
    button:hover, .btn:hover { color: var(--text); border-color: var(--violet-line); background: var(--violet-wash); }
    button.primary, .btn.primary {
      color: var(--void); background: var(--violet); border-color: var(--violet);
    }
    button.primary:hover, .btn.primary:hover { color: var(--void); background: var(--violet-2); border-color: var(--violet-2); }
    .exit::before { content: "›_"; color: var(--faint); font-weight: 800; }
    .exit:hover::before { color: var(--violet); }
    /* refresh sits in the window chrome, next to exit — a link, so it just re-GETs */
    .refresh {
      flex: none; font: 700 12.5px/1 var(--mono); letter-spacing: .02em;
      display: inline-flex; align-items: center; gap: 7px;
      color: var(--dim); border: 1px solid var(--line-2); border-radius: 7px;
      padding: 8px 13px; transition: color .15s, border-color .15s, background .15s;
    }
    .refresh:hover { color: var(--text); border-color: var(--violet-line); background: var(--violet-wash); text-decoration: none; }
    .refresh::before { content: "↻"; color: var(--faint); font-weight: 800; font-size: 13.5px; }
    .refresh:hover::before { color: var(--violet); }

    /* ---- The prompt (hero) ---- */
    .prompt {
      margin: 0; font-weight: 800;
      font-size: clamp(21px, 3.4vw, 31px); line-height: 1.15; letter-spacing: -.01em;
      color: var(--text); word-break: break-word;
    }
    .prompt .pfx { color: var(--dim); font-weight: 500; }
    .prompt .cmd { color: var(--violet-2); }
    .prompt .flag { color: var(--open); font-weight: 700; }
    .caret {
      display: inline-block; width: .58ch; height: 1.02em; margin-left: .12ch;
      background: var(--violet); vertical-align: -2px; border-radius: 1px;
      animation: blink 1.05s steps(1, end) infinite;
    }
    @keyframes blink { 50% { opacity: 0; } }

    .lede {
      font-family: var(--sans); color: var(--dim);
      font-size: 15px; line-height: 1.6; max-width: 64ch;
      margin: 14px 0 0;
    }
    .lede code { font-size: .9em; }
    .stat {
      margin: 16px 0 0; color: var(--faint); font-size: 12.5px; letter-spacing: .02em;
    }
    .stat b { color: var(--dim); font-weight: 700; }
    .stat .sep { color: var(--line-2); margin: 0 2px; }

    /* ---- Tabs = the slash-commands ---- */
    .tabs {
      display: flex; flex-wrap: wrap; gap: 4px;
      margin: 26px 0 0; padding-bottom: 0;
      border-bottom: 1px solid var(--line);
    }
    .tabs .tab {
      position: relative; margin-bottom: -1px;
      padding: 9px 13px; color: var(--dim);
      font-weight: 700; font-size: 13px; letter-spacing: .01em;
      border-bottom: 2px solid transparent;
      transition: color .15s;
    }
    .tabs .tab::before { content: "/"; color: var(--faint); margin-right: 1px; }
    .tabs .tab:hover { color: var(--text); text-decoration: none; }
    .tabs .tab.active { color: var(--text); border-bottom-color: var(--violet); }
    .tabs .tab.active::before { color: var(--violet); }

    /* ---- Status filters (flags) ---- */
    .flags { display: flex; flex-wrap: wrap; gap: 8px; margin: 22px 0 0; }
    .flags .flag {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 12px; border-radius: 7px;
      color: var(--dim); background: var(--panel-2);
      border: 1px solid var(--line); font-size: 12.5px; font-weight: 500;
      transition: color .15s, border-color .15s, background .15s;
    }
    .flags .flag:hover { color: var(--text); border-color: var(--line-2); text-decoration: none; }
    .flags .flag .glyph { font-weight: 700; }
    .flags .flag .n { color: var(--faint); font-weight: 700; font-variant-numeric: tabular-nums; }
    .flags .flag.active { color: var(--text); border-color: var(--violet-line); background: var(--violet-wash); }
    .flags .flag.active .n { color: var(--violet-2); }
    .glyph.g-all { color: var(--violet); }
    .glyph.g-open { color: var(--open); }
    .glyph.g-claimed { color: var(--claimed); }
    .glyph.g-done { color: var(--done); }

    /* ---- The board (data grid) ---- */
    .grid { margin: 22px 0 0; border: 1px solid var(--line); border-radius: 10px; overflow: hidden; background: var(--void-2); }
    /* Cap the height and let the rows scroll inside, so a long board doesn't run
       the whole page off the screen. The header stays pinned as you scroll. */
    .table-wrap {
      overflow: auto; max-height: clamp(320px, 56vh, 560px);
      scrollbar-width: thin; scrollbar-color: var(--line-2) transparent;
      overscroll-behavior: contain;
    }
    .table-wrap::-webkit-scrollbar { width: 10px; height: 10px; }
    .table-wrap::-webkit-scrollbar-track { background: transparent; }
    .table-wrap::-webkit-scrollbar-thumb {
      background: var(--line-2); border-radius: 6px; border: 2px solid var(--void-2);
    }
    .table-wrap::-webkit-scrollbar-thumb:hover { background: var(--faint); }
    .table-wrap::-webkit-scrollbar-corner { background: transparent; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    thead th {
      position: sticky; top: 0; z-index: 2;
      text-align: left; padding: 12px 16px;
      background: var(--panel-2); color: var(--faint);
      font-weight: 700; font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
      white-space: nowrap; border-bottom: 1px solid var(--line);
    }
    tbody td { padding: 13px 16px; border-bottom: 1px solid var(--line); vertical-align: top; color: var(--text); }
    tbody tr:last-child td { border-bottom: 0; }
    tbody tr { position: relative; transition: background .12s; }
    tbody tr:hover { background: var(--row-hover); }
    /* a violet edge slides in on hover — the one row micro-interaction */
    tbody td:first-child { box-shadow: inset 2px 0 0 transparent; transition: box-shadow .15s; }
    tbody tr:hover td:first-child { box-shadow: inset 2px 0 0 var(--violet); }
    td.id { color: var(--faint); white-space: nowrap; font-weight: 700; font-variant-numeric: tabular-nums; }
    td.num { font-variant-numeric: tabular-nums; white-space: nowrap; color: var(--dim); }
    .ask-text { color: var(--text); font-weight: 500; }
    a.ask-text { color: var(--text); }
    a.ask-text:hover { color: var(--violet-2); }
    .from { color: var(--dim); font-size: 11.5px; margin-top: 4px; }
    .person { color: var(--text); font-weight: 500; }
    .person .at { color: var(--faint); }
    .dash { color: var(--faint); }
    .outcome { color: var(--dim); }
    .outcome .arr { color: var(--done); margin-right: 5px; }

    /* status: the filling circle ○ ◑ ● */
    .st { display: inline-flex; align-items: center; gap: 8px; white-space: nowrap; font-weight: 500; }
    .st::before { font-weight: 700; font-size: 13px; line-height: 1; }
    .st.open::before { content: "○"; color: var(--open); }
    .st.claimed::before { content: "◑"; color: var(--claimed); }
    .st.done::before { content: "●"; color: var(--done); }

    /* urgency: a single signal dot + label */
    .urg { display: inline-flex; align-items: center; gap: 8px; white-space: nowrap; }
    .urg::before { content: "●"; font-size: 9px; line-height: 1; }
    .urg.now::before { color: var(--now); }
    .urg.EOD::before { color: var(--eod); }
    .urg.no-rush::before { color: var(--norush); }

    /* leaderboard rank */
    .rank { font-weight: 800; font-variant-numeric: tabular-nums; color: var(--dim); }
    .rank::before { content: "#"; color: var(--faint); }
    .rank.r1 { color: var(--violet-2); }
    .rank.r2 { color: var(--claimed); }
    .rank.r3 { color: var(--open); }

    /* ---- Stalled summary ---- */
    .summary {
      display: inline-flex; align-items: center; gap: 9px;
      margin: 22px 0 0; padding: 9px 14px;
      color: var(--open); background: rgba(224,163,60,.08);
      border: 1px solid rgba(224,163,60,.28); border-radius: 8px;
      font-size: 13px; font-weight: 500;
    }
    .summary::before { content: "!"; font-weight: 800; color: var(--open); }

    /* ---- Empty state ---- */
    .empty {
      margin: 22px 0 0; text-align: left;
      padding: 34px 26px; color: var(--dim);
      background: var(--void-2); border: 1px solid var(--line); border-radius: 10px;
    }
    .empty .lead { color: var(--text); font-weight: 700; font-size: 15px; margin: 0 0 6px; }
    .empty .lead::before { content: "$ "; color: var(--violet); }
    .empty p { margin: 0; font-family: var(--sans); font-weight: 400; }
    .empty p + p { margin-top: 4px; }

    @media (max-width: 620px) {
      .term { margin: 0; border-radius: 0; border-left: 0; border-right: 0; }
      /* A wide data grid can't scan on a phone, so each row prints as a stacked
         record — label on the left, value on the right, like a terminal dumping
         one record at a time. */
      .grid { background: transparent; border: 0; border-radius: 0; }
      .grid .table-wrap { overflow: visible; max-height: none; }
      .grid table, .grid tbody, .grid tr, .grid td { display: block; width: 100%; }
      .grid thead { display: none; }
      .grid tbody tr {
        padding: 13px 15px; margin: 0 0 10px;
        border: 1px solid var(--line); border-radius: 10px; background: var(--void-2);
      }
      .grid tbody tr:hover { background: var(--void-2); }
      .grid tbody tr:hover td:first-child { box-shadow: none; }
      .grid tbody td {
        position: relative; padding: 5px 0 5px 116px; border: 0; min-height: 1.6em;
      }
      .grid tbody td::before {
        content: attr(data-label); position: absolute; left: 0; top: 5px; width: 104px;
        color: var(--faint); font-size: 10.5px; font-weight: 700;
        letter-spacing: .12em; text-transform: uppercase; line-height: 1.7;
      }
      .grid tbody td.id { color: var(--dim); font-size: 13px; }
      .grid .from { margin-top: 4px; }
    }
    @media (prefers-reduced-motion: reduce) {
      .caret { animation: none; }
      * { transition: none !important; }
    }
  </style>
</head>
<body>
