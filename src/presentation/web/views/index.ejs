<%- include('partials/head', { title: 'Canany - ' + org.name }) %>
<link rel="stylesheet" href="/board.css">
<%
  const commands = { board: 'board', top: 'top', stalled: 'stalled' };
  const ledes = {
    board: "Everything anyone's asked for — what's open, who grabbed it, and how it landed",
    top: "Who's shipping and raising the most this month.",
    stalled: 'Open asks that have been waiting a while and could use a hand.'
  };
  const glyphClass = { open: 'g-open', claimed: 'g-claimed', done: 'g-done' };

  function fmtDate(value) {
    if (!value) return null;
    const date = new Date(value);
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    return year + "-" + month + "-" + day;
  }
%>

<main class="board-page">
  <header class="board-chrome" aria-label="Board navigation">
    <% if (orgs.length > 1) { %>
      <details class="board-org-switcher">
        <summary class="board-chrome__identity" aria-label="Switch organization">
          <img class="board-traffic" src="/figma/board/traffic.svg" alt="" aria-hidden="true">
          <p>Canany <span aria-hidden="true">&gt;</span> <strong><%= org.name %></strong> <em><%= commands[tab] %></em></p>
        </summary>
        <nav class="board-org-menu" aria-label="Organizations">
          <% orgs.forEach(function (item) { %>
            <a class="<%= item.id === org.id ? 'is-current' : '' %>" href="/?org=<%= item.id %>"><%= item.name %></a>
          <% }); %>
        </nav>
      </details>
    <% } else { %>
      <div class="board-chrome__identity">
        <img class="board-traffic" src="/figma/board/traffic.svg" alt="" aria-hidden="true">
        <p>Canany <span aria-hidden="true">&gt;</span> <strong><%= org.name %></strong> <em><%= commands[tab] %></em></p>
      </div>
    <% } %>

    <form class="board-close-form" method="post" action="/logout">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <button class="board-close" type="submit" aria-label="Log out">
        <img src="/figma/board/close.svg" alt="" aria-hidden="true">
      </button>
    </form>
  </header>

  <section class="board-surface" aria-labelledby="board-title">
    <header class="board-hero">
      <div class="board-intro">
        <h1 id="board-title">canany ~ <%= commands[tab] %></h1>
        <p><%= ledes[tab] %></p>
      </div>

      <nav class="board-actions" aria-label="Organization actions">
        <a class="board-action board-action--manage" href="/orgs/<%= org.id %>">
          <img src="/figma/board/manage.svg" alt="" aria-hidden="true">
          <span>Manage Connect a group</span>
        </a>
        <a class="board-action board-action--new" href="/orgs/new">
          <img src="/figma/board/new-org.svg" alt="" aria-hidden="true">
          <span>New org</span>
        </a>
      </nav>
    </header>

    <nav class="board-tabs" aria-label="Board views">
      <a class="board-tab <%= tab === 'board' ? 'is-active' : '' %>" href="/?tab=board">
        <span class="board-tab-icon board-tab-icon--board" aria-hidden="true"></span>
        <span>Board</span>
      </a>
      <a class="board-tab <%= tab === 'top' ? 'is-active' : '' %>" href="/?tab=top">
        <span class="board-tab-icon board-tab-icon--top" aria-hidden="true"></span>
        <span>Top</span>
      </a>
      <a class="board-tab <%= tab === 'stalled' ? 'is-active' : '' %>" href="/?tab=stalled">
        <span class="board-tab-icon board-tab-icon--stalled" aria-hidden="true"></span>
        <span>Stalled</span>
      </a>
    </nav>

    <% if (tab === 'board') { %>
      <%
        const filters = [{ key: 'all', label: 'All', n: total }].concat(counts.map(function (count) {
          return {
            key: count.status,
            label: count.status.charAt(0).toUpperCase() + count.status.slice(1),
            n: count.n
          };
        }));
      %>
      <nav class="board-filters" aria-label="Filter asks by status">
        <% filters.forEach(function (filter) { %>
          <a class="board-filter board-filter--<%= filter.key %> <%= status === filter.key ? 'is-active' : '' %>" href="/?tab=board&status=<%= filter.key %>">
            <span><%= filter.label %></span>
            <b><%= filter.n %></b>
          </a>
        <% }); %>
      </nav>

      <% if (!rows.length) { %>
        <section class="board-panel board-panel--empty" aria-labelledby="board-empty-title">
          <div class="board-empty-visual" aria-hidden="true">
            <img src="/figma/board/empty-state.png" alt="">
          </div>
          <div class="board-empty-copy">
            <% if (total === 0) { %>
              <h2 id="board-empty-title">No ask yet</h2>
              <p>Post one with <strong>#ask</strong> in Telegram and it shows up here.</p>
            <% } else { %>
              <h2 id="board-empty-title">Nothing <%= status %></h2>
              <p>No <%= status %> asks right now. Try another filter.</p>
            <% } %>
          </div>
        </section>
      <% } else { %>
        <section class="board-panel board-panel--table" aria-label="Tracked asks">
          <div class="board-table-wrap">
            <table class="board-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Ask</th>
                  <th>Urgency</th>
                  <th>Effort</th>
                  <th>Date of ask</th>
                  <th>Status</th>
                  <th>Who</th>
                  <th>Date of claiming</th>
                  <th>Outcome</th>
                </tr>
              </thead>
              <tbody>
                <% rows.forEach(function (row) { %>
                  <tr>
                    <td class="board-id" data-label="#"><%= String(row.id).padStart(2, '0') %></td>
                    <td class="board-ask-cell" data-label="Ask">
                      <% if (row.thread_link) { %>
                        <a class="board-ask-text" href="<%= row.thread_link %>" target="_blank" rel="noopener noreferrer"><%= row.ask %></a>
                      <% } else { %>
                        <span class="board-ask-text"><%= row.ask %></span>
                      <% } %>
                      <% if (row.asker) { %><small class="board-from">from @<%= row.asker %></small><% } %>
                      <% if (row.attachments && row.attachments.length) { %>
                        <div class="board-attachments">
                          <% row.attachments.forEach(function (attachment) { %>
                            <% const isImage = attachment.kind === 'photo' || (attachment.mime_type && attachment.mime_type.indexOf('image/') === 0); %>
                            <% if (attachment.url && isImage) { %>
                              <a class="board-attachment-thumb" href="<%= attachment.url %>" target="_blank" rel="noopener noreferrer">
                                <img src="<%= attachment.url %>" alt="<%= attachment.file_name || 'Ask attachment' %>" loading="lazy">
                              </a>
                            <% } else if (attachment.url) { %>
                              <a class="board-attachment-file" href="<%= attachment.url %>" target="_blank" rel="noopener noreferrer"><%= attachment.file_name || attachment.kind %></a>
                            <% } else if (row.thread_link) { %>
                              <a class="board-attachment-file" href="<%= row.thread_link %>" target="_blank" rel="noopener noreferrer"><%= attachment.file_name || attachment.kind %> in Telegram</a>
                            <% } else { %>
                              <span class="board-attachment-file"><%= attachment.file_name || attachment.kind %></span>
                            <% } %>
                          <% }); %>
                        </div>
                      <% } %>
                    </td>
                    <td data-label="Urgency"><% if (row.urgency) { %><span class="board-urgency <%= row.urgency %>"><%= row.urgency %></span><% } else { %><span class="board-dash">-</span><% } %></td>
                    <td class="board-num" data-label="Effort"><%= row.effort || '-' %></td>
                    <td class="board-num" data-label="Date of ask"><%= fmtDate(row.created_at) %></td>
                    <td data-label="Status"><span class="board-status <%= row.status %>"><%= row.status %></span></td>
                    <td data-label="Who"><% if (row.claimer) { %><span class="board-person">@<%= row.claimer %></span><% } else { %><span class="board-dash">-</span><% } %></td>
                    <td class="board-num" data-label="Date of claiming"><%= row.claimed_at ? fmtDate(row.claimed_at) : '-' %></td>
                    <td data-label="Outcome"><% if (row.outcome) { %><span class="board-outcome"><%= row.outcome %></span><% } else { %><span class="board-dash">-</span><% } %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </section>
      <% } %>

    <% } else if (tab === 'top') { %>
      <% if (!builders.length) { %>
        <section class="board-panel board-panel--empty board-panel--direct" aria-labelledby="top-empty-title">
          <div class="board-empty-visual" aria-hidden="true"><img src="/figma/board/empty-state.png" alt=""></div>
          <div class="board-empty-copy">
            <h2 id="top-empty-title">No closed asks yet</h2>
            <p>The leaderboard fills in as asks get claimed and shipped.</p>
          </div>
        </section>
      <% } else { %>
        <section class="board-panel board-panel--table board-panel--direct" aria-label="Top contributors">
          <div class="board-table-wrap">
            <table class="board-table board-table--compact">
              <thead><tr><th>Rank</th><th>Builder</th><th>Shipped</th><th>Raised</th></tr></thead>
              <tbody>
                <% builders.forEach(function (builder, index) { %>
                  <tr>
                    <td data-label="Rank"><span class="board-rank"><%= index + 1 %></span></td>
                    <td data-label="Builder"><span class="board-person">@<%= builder.person %></span></td>
                    <td class="board-num" data-label="Shipped"><%= builder.shipped %></td>
                    <td class="board-num" data-label="Raised"><%= builder.raised %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </section>
      <% } %>

    <% } else { %>
      <% if (!stalled.length) { %>
        <section class="board-panel board-panel--empty board-panel--direct" aria-labelledby="stalled-empty-title">
          <div class="board-empty-visual" aria-hidden="true"><img src="/figma/board/empty-state.png" alt=""></div>
          <div class="board-empty-copy">
            <h2 id="stalled-empty-title">All caught up</h2>
            <p>Nothing has been open longer than <%= days %> day<%= days === 1 ? '' : 's' %>.</p>
          </div>
        </section>
      <% } else { %>
        <section class="board-panel board-panel--table board-panel--direct" aria-labelledby="stalled-title">
          <h2 class="board-panel-title" id="stalled-title">Open longer than <%= days %> day<%= days === 1 ? '' : 's' %>. <%= stalled.length %> waiting.</h2>
          <div class="board-table-wrap">
            <table class="board-table">
              <thead><tr><th>#</th><th>Ask</th><th>Age</th><th>Status</th><th>Asker</th></tr></thead>
              <tbody>
                <% stalled.forEach(function (row) { %>
                  <tr>
                    <td class="board-id" data-label="#"><%= String(row.id).padStart(2, '0') %></td>
                    <td data-label="Ask"><span class="board-ask-text"><%= row.ask %></span></td>
                    <td class="board-num" data-label="Age"><%= row.ageDays %>d</td>
                    <td data-label="Status"><span class="board-status <%= row.status %>"><%= row.status %></span></td>
                    <td data-label="Asker"><%= row.asker ? '@' + row.asker : '-' %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </section>
      <% } %>
    <% } %>
  </section>
</main>
<%- include('partials/foot') %>
