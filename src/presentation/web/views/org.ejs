<%- include('partials/head', { title: 'Canany - ' + org.name }) %>
<link rel="stylesheet" href="/connect.css">

<main class="connect-page">
  <header class="connect-chrome" aria-label="Organization navigation">
    <div class="connect-chrome__identity">
      <img class="connect-traffic" src="/figma/connect/traffic.svg" alt="" aria-hidden="true">
      <p>Canany <span aria-hidden="true">&gt;</span> <strong><%= org.name %></strong></p>
    </div>
    <a class="connect-close" href="/" aria-label="Close connection setup and return to the board">
      <img src="/figma/connect/close.svg" alt="" aria-hidden="true">
    </a>
  </header>

  <section class="connect-surface" aria-labelledby="connect-title">
    <header class="connect-intro">
      <h1 id="connect-title">canany ~ connect</h1>
      <p>Link a Telegram group to <%= org.name %> in two steps. Once connected, that group's <a href="#connected-groups">#asks</a> show up on this org's board.</p>
    </header>

    <div class="connect-steps">
      <span class="connect-step-line" aria-hidden="true"></span>

      <article class="connect-step connect-step--bot">
        <span class="connect-step-number" aria-hidden="true">1</span>
        <div class="connect-step-layout">
          <div class="connect-step-main">
            <span class="connect-step-icon connect-step-icon--bot" aria-hidden="true">
              <img class="connect-bot-icon" src="/figma/connect/bot.svg" alt="">
              <img class="connect-plus-icon" src="/figma/connect/plus.svg" alt="">
            </span>
            <div class="connect-step-copy">
              <h2>Add the bot to your group</h2>
              <p>Open Telegram and add the bot to the group you want this org to track</p>
            </div>
          </div>

          <% if (botLink) { %>
            <a class="connect-action connect-action--primary" href="<%= botLink %>" target="_blank" rel="noopener noreferrer">
              <img src="/figma/connect/telegram.svg" alt="" aria-hidden="true">
              <span>Add the bot to your group</span>
            </a>
          <% } else { %>
            <span class="connect-action connect-action--primary is-disabled" aria-disabled="true" title="Set BOT_USERNAME to enable this link">
              <img src="/figma/connect/telegram.svg" alt="" aria-hidden="true">
              <span>Add the bot to your group</span>
            </span>
          <% } %>
        </div>
      </article>

      <article class="connect-step connect-step--command">
        <span class="connect-step-number" aria-hidden="true">2</span>
        <img class="connect-small-chain" src="/figma/connect/small-chain.svg" alt="" aria-hidden="true">
        <div class="connect-step-layout">
          <div class="connect-step-main">
            <span class="connect-step-icon connect-step-icon--chain" aria-hidden="true">
              <img src="/figma/connect/chain.svg" alt="">
            </span>
            <div class="connect-step-copy">
              <h2>Run the connect command</h2>
              <% if (token) { %>
                <p>In that group, send this — the token is one-time and expires, so don't share it publicly:</p>
              <% } else { %>
                <p>No active token right now. Generate one, then send the command inside your Telegram group.</p>
              <% } %>
            </div>
          </div>

          <div class="connect-token-actions">
            <% if (token) { %>
              <div class="connect-token">
                <code id="connect-command">/connect <%= token.token %></code>
                <button class="connect-copy" type="button" data-copy-target="connect-command" aria-label="Copy connect command">
                  <img src="/figma/connect/copy.svg" alt="" aria-hidden="true">
                </button>
              </div>
            <% } else { %>
              <div class="connect-token connect-token--empty">
                <span>No active connect token</span>
              </div>
            <% } %>

            <form method="post" action="/orgs/<%= org.id %>/token">
              <input type="hidden" name="_csrf" value="<%= csrf %>">
              <button class="connect-action connect-action--secondary" type="submit">
                <img src="/figma/connect/regenerate.svg" alt="" aria-hidden="true">
                <span><%= token ? 'Regenerate token' : 'Generate token' %></span>
              </button>
            </form>
          </div>
        </div>
      </article>

      <section class="connect-groups" id="connected-groups" aria-labelledby="connected-title">
        <img class="connect-tick" src="/figma/connect/tick.svg" alt="" aria-hidden="true">
        <div class="connect-groups-copy">
          <h2 id="connected-title">Connected groups</h2>
          <% if (connectedGroups && connectedGroups.length) { %>
            <ul class="connect-groups-list">
              <% connectedGroups.forEach(function (group) { %>
                <li>
                  <span><%= group.title ? group.title : 'Connected group' %></span>
                  <small><%= group.tg_chat_id %></small>
                </li>
              <% }); %>
            </ul>
          <% } else { %>
            <p>No groups connected yet — run the command above inside your group.</p>
          <% } %>
        </div>
        <a class="connect-board-link" href="/">
          <span>View this org's board</span>
          <img src="/figma/connect/arrow.svg" alt="" aria-hidden="true">
        </a>
      </section>
    </div>

    <p class="connect-note">
      <img src="/figma/connect/info.svg" alt="" aria-hidden="true">
      <span>connect tokens are one-time &amp; expiring <span aria-hidden="true">·</span> regenerating invalidates the old one</span>
    </p>

    <p class="connect-copy-status sr-only" role="status" aria-live="polite"></p>
  </section>
</main>

<script src="/connect.js" defer></script>
<%- include('partials/foot') %>
