<%- include('partials/head', { title: 'canany — login' }) %>
<%- include('partials/form-styles') %>
<div class="auth-wrap">
  <div class="term auth">
    <div class="term__bar">
      <span class="dots" aria-hidden="true"><span class="d-now"></span><span class="d-eod"></span><span class="d-norush"></span></span>
      <span class="term__title"><b>canany</b> — login</span>
    </div>
    <div class="term__body">
      <h1 class="prompt"><span class="pfx">canany&nbsp;~&nbsp;%</span> <span class="cmd">login</span><span class="caret" aria-hidden="true"></span></h1>
      <p class="lede">Sign in to your boards. The Telegram bot stays the source of truth — this is where you manage orgs and watch each group's board.</p>
      <% if (error) { %>
        <p class="err"><%= error %></p>
      <% } %>
      <form method="post" action="/login">
        <div class="row">
          <label for="email">Email</label>
          <div class="field">
            <input id="email" type="email" name="email" value="<%= email %>" placeholder="you@example.com" autofocus autocomplete="email" required>
          </div>
        </div>
        <div class="row">
          <label for="password">Password</label>
          <div class="field">
            <input id="password" type="password" name="password" placeholder="••••••••" autocomplete="current-password" required>
          </div>
        </div>
        <button type="submit" class="primary">Log in</button>
      </form>
      <p class="alt">No account? <a href="/signup">Sign up →</a></p>
    </div>
  </div>
</div>
<%- include('partials/foot') %>
