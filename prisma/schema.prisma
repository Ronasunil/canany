// Prisma schema — the single source of truth for the database.
// Field names are kept snake_case to match the columns the app already reads,
// so swapping pg -> Prisma stays contained to the data layer.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The one ledger table. Maps to "asks".
model Ask {
  id          Int       @id @default(autoincrement())
  ask         String
  asker       String
  asker_id    String? // Telegram user id of the asker — the spoof-proof identity for "asker-only" actions
  effort      String? // free-form estimate: '1 hr', '2 days', 'a month'
  urgency     String? // 'now' | 'EOD' | 'no-rush' (validated in app code)
  status      String    @default("open") // 'open' | 'claimed' | 'done'
  claimer     String?
  claimer_id  String? // Telegram user id of the claimer — the spoof-proof identity for "claimer-only" actions
  outcome     String? // required to reach 'done'
  thread_link String? // deep link back to the Telegram thread
  tg_chat_id  String? // Telegram ids stored as text (identifiers, never math)
  tg_topic_id String?
  tg_msg_id   String? // the original ask message
  tg_card_id  String? // the bot's reply card we keep editing
  // Denormalized org — stamped at createAsk from the group->org lookup. Nullable so
  // legacy/DM asks keep working; snapshots the org the ask was raised under, so
  // re-connecting a group to a new org never moves history (see the plan's notes).
  org_id      Int?
  org         Org?      @relation(fields: [org_id], references: [id], onDelete: SetNull)
  created_at  DateTime  @default(now())
  claimed_at  DateTime?
  closed_at   DateTime?
  attachments AskAttachment[]

  @@index([status])
  @@index([created_at])
  @@index([org_id, status])
  @@index([org_id, created_at])
  @@map("asks")
}

// A web account. Owns one or more orgs. Email stored normalized (trim+lowercase).
model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
  orgs          Org[]

  @@map("users")
}

// A tenant. Every board (bot + web) is scoped to exactly one org. `origin`
// distinguishes orgs created through the web ('web') from those the backfill
// minted for pre-existing Telegram groups ('migrated').
model Org {
  id            Int            @id @default(autoincrement())
  name          String
  origin        String         @default("web") // 'web' | 'migrated'
  owner_user_id Int?
  owner         User?          @relation(fields: [owner_user_id], references: [id])
  created_at    DateTime       @default(now())
  groups        Group[]
  tokens        ConnectToken[]
  asks          Ask[]

  @@index([owner_user_id])
  @@map("orgs")
}

// A Telegram chat linked to an org via /connect. One chat -> exactly one org;
// tg_chat_id is the upsert key, so re-connecting re-points the same row.
model Group {
  id           Int       @id @default(autoincrement())
  tg_chat_id   String    @unique
  org_id       Int
  org          Org       @relation(fields: [org_id], references: [id], onDelete: Cascade)
  title        String?
  connected_by String? // tg user id who ran /connect (null if migrated)
  connected_at DateTime?
  created_at   DateTime  @default(now())

  @@index([org_id])
  @@map("groups")
}

// A one-time, short-lived bearer that /connect burns to link a group to an org.
// Plaintext (it's short-lived) and single-use (used_at flips on consume).
model ConnectToken {
  id              Int       @id @default(autoincrement())
  token           String    @unique
  org_id          Int
  org             Org       @relation(fields: [org_id], references: [id], onDelete: Cascade)
  expires_at      DateTime
  used_at         DateTime? // null = still consumable
  used_by_chat_id String?
  created_at      DateTime  @default(now())

  @@index([org_id])
  @@map("connect_tokens")
}

// A file attached to an #ask (photo, document, …). The bytes live in S3; we store
// the object key + Telegram/media metadata. Captured at ask creation from the
// #ask message (or its album). Cascade-deletes with its ask — no orphan rows.
model AskAttachment {
  id                Int      @id @default(autoincrement())
  ask_id            Int
  ask               Ask      @relation(fields: [ask_id], references: [id], onDelete: Cascade)
  kind              String // 'photo' | 'document' | 'video' | 'audio' | 'voice' | 'animation'
  s3_key            String? // object key in the private bucket; null when the file was >20MB (a bot can't download it from Telegram)
  tg_file_id        String? // Telegram handle — provenance / re-fetch fallback
  tg_file_unique_id String? // stable per-file id; part of the S3 key
  file_name         String?
  mime_type         String?
  file_size         Int?
  width             Int? // photos/videos
  height            Int?
  created_at        DateTime @default(now())

  @@index([ask_id])
  @@map("ask_attachments")
}
