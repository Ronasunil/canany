# ---- Telegram ----
# From BotFather. Keep this secret.
BOT_TOKEN=123456789:AA-your-bot-token-here

# ---- PostgreSQL (Prisma reads this) ----
# Prisma uses DATABASE_URL for both the app and migrations.
# Create the DB + tables with `npm run db:dev` (prisma migrate dev).
DATABASE_URL=postgres://canany:canany@localhost:5432/canany

# ---- Behaviour (optional; defaults shown) ----
# The prefix that marks a message as a new ask (it's stripped before saving).
# Quote it — a bare # starts a comment in .env, so ASK_PREFIX=#ask parses as empty.
ASK_PREFIX="#ask"
# /stalled flags asks left open longer than this many days.
STALLED_DAYS=2
