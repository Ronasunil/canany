# ---- Telegram ----
# From BotFather. Keep this secret.
BOT_TOKEN=123456789:AA-your-bot-token-here

# ---- PostgreSQL (Prisma reads this) ----
# Prisma uses DATABASE_URL for both the app and migrations.
# Create the DB + tables with `npm run db:dev` (prisma migrate dev).
DATABASE_URL=postgres://canany:canany@localhost:5432/canany

# ---- Behaviour (optional; defaults shown) ----
# The prefix that marks a message as a new ask (it's stripped before saving).
# Quote it — a bare # starts a comment in .env, so ASK_PREFIX=#ask parses as empty.
ASK_PREFIX="#ask"
# /stalled flags asks left open longer than this many days.
STALLED_DAYS=2

# ---- Web board (optional) ----
# Leave WEB_PASSWORD blank to run the bot only. Set it to enable a read-only
# web board at http://<host>:<WEB_PORT> behind this single shared password.
WEB_PASSWORD=
# Required when WEB_PASSWORD is set — signs the login cookie. Use 32+ random
# chars, e.g. `openssl rand -hex 32`.
SESSION_SECRET=
# Port the web board listens on (default 8080). Open this port on the firewall.
WEB_PORT=8080
# Set to true only when the site is served over HTTPS (e.g. behind a TLS proxy),
# so the login cookie is marked Secure.
WEB_SECURE_COOKIE=false
