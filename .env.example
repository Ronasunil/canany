# ---- Telegram ----
# From BotFather. Keep this secret.
BOT_TOKEN=123456789:AA-your-bot-token-here
# The bot's @username (without the @). Required when the web board is enabled —
# it builds the "Add the bot to your group" link: https://t.me/<BOT_USERNAME>?startgroup=true
BOT_USERNAME=YourBot

# ---- PostgreSQL (Prisma reads this) ----
# Prisma uses DATABASE_URL for both the app and migrations.
# Create the DB + tables with `npm run db:dev` (prisma migrate dev).
DATABASE_URL=postgres://canany:canany@localhost:5432/canany

# ---- Behaviour (optional; defaults shown) ----
# The prefix that marks a message as a new ask (it's stripped before saving).
# Quote it — a bare # starts a comment in .env, so ASK_PREFIX=#ask parses as empty.
ASK_PREFIX="#ask"
# /stalled flags asks left open longer than this many days.
STALLED_DAYS=2

# ---- Web board (on by default) ----
# The web board (signup -> create org -> connect token) is the product front door
# and runs in the same process. Set WEB_ENABLED=false for a pure-bot deploy.
WEB_ENABLED=true
WEB_ONLY=false
# Set WEB_ONLY=true locally to preview the web UI without starting Telegram polling.
# Required when the web is enabled — signs the session cookie. Use 32+ random
# chars, e.g. `openssl rand -hex 32`.
SESSION_SECRET=
# Optional bootstrap kill-switch. Leave blank for open signup; set it to require
# this code on the signup form (gate signups to invited users).
SIGNUP_CODE=
# Port the web board listens on (default 8080). Open this port on the firewall.
WEB_PORT=8080
# Set to true only when the site is served over HTTPS (e.g. behind a TLS proxy),
# so the session cookie is marked Secure.
WEB_SECURE_COOKIE=false

# ---- Attachments (optional; S3 storage for files sent with an #ask) ----
# Set both to store docs/images that people attach to an #ask. Leave blank to
# disable attachments (asks still work text-only). The bucket must be private.
# Credentials are read by the AWS SDK's default chain — use an IAM instance role
# in prod, or set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY locally (not here).
AWS_REGION=
S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
